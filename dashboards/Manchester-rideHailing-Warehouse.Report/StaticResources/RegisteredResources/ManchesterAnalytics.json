{
  "name": "Manchester Ride-Hailing Enterprise Theme",
  "dataColors": [
    "#2E75B6",
    "#2ECC71",
    "#F39C12",
    "#5DADE2",
    "#7E57C2",
    "#16A085",
    "#E74C3C",
    "#7F8C8D",
    "#1F4E79",
    "#2C3E50"
  ],
  "background": "#F4F7FA",
  "foreground": "#1F2937",
  "tableAccent": "#0F4C81",
  "good": "#2ECC71",
  "neutral": "#F39C12",
  "bad": "#E74C3C",
  "maximum": "#0F4C81",
  "center": "#EAF2F8",
  "minimum": "#DDEBFF",
  "null": "#BDC3C7",
  "textClasses": {
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 32,
      "color": "#1A1A2E"
    },
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 12,
      "color": "#1A1A2E"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 11,
      "color": "#1A1A2E"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 10,
      "color": "#3B3B4F"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#D9E2EC"
              }
            },
            "radius": 8
          }
        ],
        "dropShadow": [
          {
            "show": true,
            "preset": "0",
            "position": "Outer",
            "shadowColor": {
              "solid": {
                "color": "#1F2937"
              }
            },
            "shadowTransparency": 88,
            "angle": 90,
            "distance": 3,
            "blur": 8
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#1F2937"
              }
            },
            "background": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold",
            "alignment": "left"
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": {
              "solid": {
                "color": "#F7F9FB"
              }
            }
          }
        ],
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#F7F9FB"
              }
            }
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#F4F7FA"
              }
