        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#1F2937"
              }
            },
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    },
    "multiRowCard": {
